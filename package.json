{
  "name": "forge",
  "version": "0.1.0",
  "private": true,
  "description": "Feedback-Optimized Reinforcement Generation Engine",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=@forge/core && npm run build --workspace=@forge/rewards && npm run build --workspace=@forge/mcp",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "@types/node": "^22.15.32"
  }
}
